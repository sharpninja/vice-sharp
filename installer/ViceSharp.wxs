<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    ViceSharp MSI installer.

    The package is a per-machine install that drops the published
    ViceSharp.Avalonia desktop GUI (self-contained, with all 390+ runtime
    DLLs and Avalonia's native bits) into Program Files\ViceSharp\, adds
    a Start menu shortcut, and stamps the version into Add/Remove Programs.

    PublishedRoot is provided by the build system as a WiX preprocessor
    variable (`-d PublishedRoot=...`) so the installer can find the
    publish output regardless of where the build host puts it. The
    Files element auto-harvests every file under that directory tree.
  -->

  <?define ProductName = "ViceSharp" ?>
  <?define Manufacturer = "sharpninja" ?>
  <?define UpgradeCodeGuid = "6F8B1C4E-7A2D-4E5B-9F3A-1C8E5B7D9F2A" ?>
  <?define EntryExe = "ViceSharp.Avalonia.exe" ?>

  <Package Name="$(ProductName)"
           Manufacturer="$(Manufacturer)"
           Version="$(var.ProductVersion)"
           UpgradeCode="$(UpgradeCodeGuid)"
           Scope="perMachine">

    <MajorUpgrade AllowSameVersionUpgrades="yes"
                  DowngradeErrorMessage="A newer version of $(ProductName) is already installed." />

    <!--
      BRANDING-ICON-001: product icon for Add/Remove Programs and the Start
      menu shortcut. The Icon Id must end in .ico so WiX infers the type.
      Sourced from the committed Avalonia asset (same .ico embedded in the exe).
    -->
    <Icon Id="ProductIcon.ico" SourceFile="..\src\ViceSharp.Avalonia\Assets\vicesharp.ico" />
    <Property Id="ARPPRODUCTICON" Value="ProductIcon.ico" />

    <!--
      CompressionLevel="high" uses LZX instead of the default mszip; for the
      Avalonia publish output this cuts the cab by ~20% with a small
      additional install-time CPU cost. EmbedCab keeps the package as a
      single .msi (no external .cab).
    -->
    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ViceSharp" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuShortcutDir" Name="$(ProductName)">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="StartMenuShortcut"
                    Name="$(ProductName)"
                    Description="VICE-compatible Commodore 64 emulator"
                    Target="[INSTALLFOLDER]$(EntryExe)"
                    WorkingDirectory="INSTALLFOLDER"
                    Icon="ProductIcon.ico" />
          <RemoveFolder Id="StartMenuShortcutDir" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\$(Manufacturer)\$(ProductName)"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main"
             Title="ViceSharp"
             Level="1"
             AllowAdvertise="no"
             InstallDefault="local"
             TypicalDefault="install">
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentRef Id="StartMenuShortcut" />
      <?if $(var.EnableDebugGrpc) = "true" ?>
      <ComponentRef Id="DebugGrpcEnvironment" />
      <?endif?>
    </Feature>

  </Package>

  <?if $(var.EnableDebugGrpc) = "true" ?>
  <Fragment>
    <!--
      Debug MSI only: make both gRPC debugger surfaces available to a freshly
      launched installed app. The host/control gRPC surface already starts in
      process and writes the debug-attach file; VICESHARP_GRPC_REFLECTION=1
      enables grpcurl-style introspection. The Avalonia RemoteControl surface is
      otherwise fail-closed unless ENABLE + TOKEN are present, so install a
      loopback-only diagnostic token and fixed port for attach tooling.
    -->
    <DirectoryRef Id="INSTALLFOLDER">
      <Component Id="DebugGrpcEnvironment" Guid="*">
        <Environment Id="EnvViceSharpGrpcReflection"
                     Name="VICESHARP_GRPC_REFLECTION"
                     Value="1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlEnable"
                     Name="VICESHARP_REMOTECONTROL_ENABLE"
                     Value="1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlToken"
                     Name="VICESHARP_REMOTECONTROL_TOKEN"
                     Value="$(var.RemoteControlToken)"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlHost"
                     Name="VICESHARP_REMOTECONTROL_HOST"
                     Value="127.0.0.1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlPort"
                     Name="VICESHARP_REMOTECONTROL_PORT"
                     Value="$(var.RemoteControlPort)"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlActions"
                     Name="VICESHARP_REMOTECONTROL_ALLOW_ACTIONS"
                     Value="1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlFrames"
                     Name="VICESHARP_REMOTECONTROL_ALLOW_FRAMES"
                     Value="1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <Environment Id="EnvViceSharpRemoteControlInput"
                     Name="VICESHARP_REMOTECONTROL_ALLOW_INPUT"
                     Value="1"
                     Action="set"
                     Part="all"
                     System="yes" />
        <RegistryValue Root="HKLM"
                       Key="Software\$(Manufacturer)\$(ProductName)\DebugGrpc"
                       Name="enabled"
                       Type="integer"
                       Value="1"
                       KeyPath="yes" />
      </Component>
    </DirectoryRef>
  </Fragment>
  <?endif?>

  <Fragment>
    <!--
      Auto-harvest every file under the publish output. WiX 5 generates a
      Component per file with hash-based stable IDs and lays out the
      directory structure under INSTALLFOLDER. No Heat invocation needed.

      Exclusions reclaim the bulk of the install size:
        *.pdb : managed + native debug symbols (libSkiaSharp.pdb alone is
                84 MB, libHarfBuzzSharp.pdb is 21 MB). End users never
                attach a debugger from inside Program Files.
        *.xml : per-assembly XML doc comments. Not useful at runtime.
        createdump.exe : .NET crash dumper. Optional; we keep crashes to
                Event Log instead.
        *.dbg : ELF separate-debug files (rare but harmless to exclude).
    -->
    <ComponentGroup Id="HarvestedFiles" Directory="INSTALLFOLDER">
      <!--
        File exclusions (*.pdb, *.xml, createdump.exe, etc.) are applied
        in Build.cs PublishMsi by deleting them from PublishedRoot AFTER
        the publish and BEFORE this Files harvest. WiX 5's Files element
        only supports Include, so the filter has to happen upstream.
      -->
      <Files Include="$(var.PublishedRoot)\**" />
    </ComponentGroup>
  </Fragment>

</Wix>
