<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">

  <!--
    ViceSharp MSI installer.

    The package is a per-machine install that drops the published
    ViceSharp.Avalonia desktop GUI (self-contained, with all 390+ runtime
    DLLs and Avalonia's native bits) into Program Files\ViceSharp\, adds
    a Start menu shortcut, and stamps the version into Add/Remove Programs.

    PublishedRoot is provided by the build system as a WiX preprocessor
    variable (`-d PublishedRoot=...`) so the installer can find the
    publish output regardless of where the build host puts it. The
    Files element auto-harvests every file under that directory tree.
  -->

  <?define ProductName = "ViceSharp" ?>
  <?define Manufacturer = "sharpninja" ?>
  <?define UpgradeCodeGuid = "6F8B1C4E-7A2D-4E5B-9F3A-1C8E5B7D9F2A" ?>
  <?define EntryExe = "ViceSharp.Avalonia.exe" ?>

  <Package Name="$(ProductName)"
           Manufacturer="$(Manufacturer)"
           Version="$(var.ProductVersion)"
           UpgradeCode="$(UpgradeCodeGuid)"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of $(ProductName) is already installed." />

    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="ViceSharp" />
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="StartMenuShortcutDir" Name="$(ProductName)">
        <Component Id="StartMenuShortcut" Guid="*">
          <Shortcut Id="StartMenuShortcut"
                    Name="$(ProductName)"
                    Description="VICE-compatible Commodore 64 emulator"
                    Target="[INSTALLFOLDER]$(EntryExe)"
                    WorkingDirectory="INSTALLFOLDER" />
          <RemoveFolder Id="StartMenuShortcutDir" On="uninstall" />
          <RegistryValue Root="HKCU"
                         Key="Software\$(Manufacturer)\$(ProductName)"
                         Name="installed"
                         Type="integer"
                         Value="1"
                         KeyPath="yes" />
        </Component>
      </Directory>
    </StandardDirectory>

    <Feature Id="Main"
             Title="ViceSharp"
             Level="1"
             AllowAdvertise="no"
             InstallDefault="local"
             TypicalDefault="install">
      <ComponentGroupRef Id="HarvestedFiles" />
      <ComponentRef Id="StartMenuShortcut" />
    </Feature>

  </Package>

  <Fragment>
    <!--
      Auto-harvest every file under the publish output. WiX 5 generates a
      Component per file with hash-based stable IDs and lays out the
      directory structure under INSTALLFOLDER. No Heat invocation needed.
    -->
    <ComponentGroup Id="HarvestedFiles" Directory="INSTALLFOLDER">
      <Files Include="$(var.PublishedRoot)\**" />
    </ComponentGroup>
  </Fragment>

</Wix>
