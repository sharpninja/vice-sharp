<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Vendored SharpNinja.Avalonia.RemoteControl.* packages (0.7.3) so restore
         is reproducible on Azure DevOps / CI without the sibling source repo. -->
    <add key="vicesharp-local" value="nuget-local" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="vicesharp-local">
      <package pattern="SharpNinja.Avalonia.RemoteControl.*" />
      <!-- Locally vendored aiUnit 2.0.0-beta.20 (xUnit v3). Not yet on nuget.org;
           packed from F:\GitHub\aiUnit (HEAD 309cf2c, GitVersion 2.0.0-beta.20) and
           dropped into nuget-local/ so the AiReview test project restores reproducibly. -->
      <package pattern="SharpNinja.aiUnit*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
