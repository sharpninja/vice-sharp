<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Vendored SharpNinja.Avalonia.RemoteControl.* packages (0.7.3) so restore
         is reproducible on Azure DevOps / CI without the sibling source repo. -->
    <add key="vicesharp-local" value="nuget-local" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="vicesharp-local">
      <package pattern="SharpNinja.Avalonia.RemoteControl.*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
