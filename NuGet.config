<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <!-- Vendored feed retained ONLY for SharpNinja.aiUnit until the AiReview
         project moves to the nuget.org release (upgrade slice S6). The
         SharpNinja.Avalonia.RemoteControl.* trio now restores from nuget.org
         (0.7.4). -->
    <add key="vicesharp-local" value="nuget-local" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="vicesharp-local">
      <package pattern="SharpNinja.aiUnit*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
