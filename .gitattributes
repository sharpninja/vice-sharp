# Disable automatic line ending conversion
* -text

# Explicitly set line endings for known text file types
*.cs      text eol=lf
*.cshtml  text eol=lf
*.csproj  text eol=lf
*.props   text eol=lf
*.targets text eol=lf
*.sln     text eol=lf
*.json    text eol=lf
*.md      text eol=lf
*.xml     text eol=lf
*.config  text eol=lf
*.cmd     text eol=crlf
*.bat     text eol=crlf
*.ps1     text eol=crlf
*.sh      text eol=lf

# Patch files carry unified-diff context lines where a blank line is encoded as
# a single space; that is valid content, not a whitespace error. Skip the
# whitespace check so `git diff --check` does not flag generated .patch files.
*.patch   text eol=lf -whitespace

# Binary files - never modify
*.png     binary
*.jpg     binary
*.gif     binary
*.ico     binary
*.rom     binary
*.bin     binary
*.dll     binary
*.exe     binary
*.so      binary
*.dylib   binary