+  // VICE-Sharp S9 parity probe: export internal filter state for managed
+  // lockstep against the reSID oracle. Test-only accessor.
+  //   [0]=Vlp [1]=Vbp [2]=Vhp [3]=v1 [4]=v2 [5]=v3 [6]=sum [7]=mix [8]=output()
+  void vsharp_probe(int* out) {
+    out[0] = Vlp; out[1] = Vbp; out[2] = Vhp;
+    out[3] = v1;  out[4] = v2;  out[5] = v3;
+    out[6] = (int)sum; out[7] = (int)mix;
+    out[8] = (int)output();
+  }
+
 protected:
   void set_sum_mix();
   void set_w0();
@@ -659,8 +669,14 @@ private:
     public:
         Randomnoise()
         {
+            // VICE-Sharp parity oracle: the stock reSID dither is
+            // buffer[i] = rand() % (1<<19), which is NON-DETERMINISTIC (varies per
+            // SID instance and run, since VICE never seeds rand()). It cannot be
+            // bit-reproduced and violates the determinism the parity oracle
+            // requires, so the dither is zeroed here. The managed Sid6581 likewise
+            // omits it; the deterministic filter model is compared bit-exactly.
             for (int i=0; i<1024; i++)
