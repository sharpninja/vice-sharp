@@ -551,6 +551,16 @@ public:
   // SID audio output (16 bits).
   short output();
 
+  // VICE-Sharp S9 parity probe: export internal filter state for managed
+  // lockstep against the reSID oracle. Diagnostic accessor only.
+  void vsharp_probe(int* out) {
+    out[0] = Vlp; out[1] = Vbp; out[2] = Vhp;
+    out[3] = v1;  out[4] = v2;  out[5] = v3;
+    out[6] = (int)sum; out[7] = (int)mix;
+    out[8] = (int)output();
+    out[9] = Vlp_x; out[10] = Vlp_vc; out[11] = Vbp_x; out[12] = Vbp_vc;
+  }
+
 protected:
   void set_sum_mix();
   void set_w0();
diff --git a/vice/src/sid/resid.cc b/vice/src/sid/resid.cc
