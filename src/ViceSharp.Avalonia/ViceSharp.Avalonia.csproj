<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <!-- BRANDING-ICON-001: embed the Commodore chicken-head icon in the
         Windows PE (Explorer, taskbar pin, MSI shortcut all inherit it). -->
    <ApplicationIcon>Assets\vicesharp.ico</ApplicationIcon>
    <AvaloniaUseCompiledBindingsByDefault>true</AvaloniaUseCompiledBindingsByDefault>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!--
      PLATFORM-CROSS-001: This desktop exe is also referenced by the iOS /
      Android host shells for the shared App/MainWindow types. Without this
      flag the mobile (self-contained) heads fail with NETSDK1150 because
      this project is non self-contained. Suppressing the executable check
      keeps the desktop run path intact while allowing the mobile shells
      to compile.
    -->
    <ShouldBeValidatedAsExecutableReference>false</ShouldBeValidatedAsExecutableReference>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Avalonia" />
    <PackageReference Include="Avalonia.Desktop" />
    <PackageReference Include="Avalonia.Themes.Fluent" />
    <PackageReference Include="Avalonia.Fonts.Inter" />
    <PackageReference Include="Grpc.Net.Client" />
  </ItemGroup>

  <!-- UI-REMOTECTRL-001: embeddable Avalonia visual-tree inspection/control
       server over gRPC. Debug-only dev tooling, disabled at runtime by default
       (opt-in via VICESHARP_REMOTECONTROL_* env switches). Excluded from the
       NativeAOT/trimmed publish that feeds the MSI: the gRPC server SDK is not
       trim/AOT-safe (IL2104 + ilc failure), and it is not needed in a shipped
       build. The REMOTECONTROL define gates the wiring in App.axaml.cs. -->
  <PropertyGroup Condition="'$(PublishAot)' != 'true'">
    <DefineConstants>$(DefineConstants);REMOTECONTROL</DefineConstants>
  </PropertyGroup>
  <ItemGroup Condition="'$(PublishAot)' != 'true'">
    <PackageReference Include="SharpNinja.Avalonia.RemoteControl.Server" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\ViceSharp.Host\ViceSharp.Host.csproj" />
    <ProjectReference Include="..\ViceSharp.Protocol\ViceSharp.Protocol.csproj" />
  </ItemGroup>

  <!-- BRANDING-ICON-001: pack the app icon PNG so the Avalonia runtime can
       load it as the WindowIcon (Icon="/Assets/...") on every head that
       reuses this project (desktop, macOS, mobile). -->
  <ItemGroup>
    <AvaloniaResource Include="Assets/**" />
  </ItemGroup>

  <!-- SETTINGS-INI-001: deploy the bootstrap appsettings.json. It only selects
       the folder for the INI files (vice.ini / vice-sharp.ini); see
       ViceConfigLocator. Lands in the publish output and thus the MSI. -->
  <ItemGroup>
    <Content Include="appsettings.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </Content>
  </ItemGroup>
</Project>
